<mui:ModernDialog x:Class="AcManager.UiObserver.WheelConfigDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mui="http://firstfloorsoftware.com/ModernUI"
                  Title="Configure Wheel Navigation"
                  Width="600" Height="400"
                  ShowTitle="True"
                  ResizeMode="NoResize"
                  WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <!-- Device Selection Panel -->
        <StackPanel x:Name="DeviceSelectionPanel" Visibility="Collapsed">
            <TextBlock Text="Select Your Wheel" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Multiple wheels detected. Select the one you want to use for navigation:" 
                       TextWrapping="Wrap" Margin="0,0,0,10"/>
            <ListBox x:Name="DeviceListBox" Height="200" Margin="0,0,0,20"
                     SelectionChanged="OnDeviceSelected">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" FontSize="14" Padding="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Content="Continue" Click="OnContinueClicked" 
                    IsEnabled="False" x:Name="ContinueButton"
                    Padding="20,10" HorizontalAlignment="Right"/>
        </StackPanel>
        
        <!-- Button Capture Panel -->
        <StackPanel x:Name="ButtonCapturePanel" Visibility="Collapsed">
            <TextBlock x:Name="StepTitle" FontSize="24" FontWeight="Bold" 
                       TextAlignment="Center" Margin="0,40,0,20"/>
            <TextBlock x:Name="StepPrompt" FontSize="18" 
                       TextAlignment="Center" Margin="0,0,0,40" 
                       Foreground="Gray"/>
            <TextBlock x:Name="StepProgress" FontSize="14" 
                       TextAlignment="Center" 
                       Foreground="DarkGray"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                <Button Content="Cancel" Click="OnCancelClicked" 
                        Padding="20,10" Margin="0,0,10,0"/>
                <Button Content="Reset" Click="OnResetClicked" 
                        Padding="20,10" x:Name="ResetButton" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Completion Panel -->
        <StackPanel x:Name="CompletionPanel" Visibility="Collapsed">
            <TextBlock Text="✓ Configuration Complete!" FontSize="24" FontWeight="Bold" 
                       TextAlignment="Center" Margin="0,40,0,20" Foreground="Green"/>
            <TextBlock x:Name="CompletionSummary" FontSize="14" 
                       TextWrapping="Wrap" Margin="0,0,0,40"/>
            <Button Content="Done" Click="OnDoneClicked" 
                    Padding="30,10" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</mui:ModernDialog>
